# Copy to backend/.env and fill in values.

# --- TURN / ICE ---
# Shared secret with coturn. Must match TURN_SECRET in the root .env used by
# docker-compose. Generate with: openssl rand -hex 32
TURN_SECRET=

# Hostname clients should reach coturn at. localhost for local dev, your LAN
# IP for cross-machine testing, your VM's public IP / domain for production.
TURN_HOST=localhost
TURN_PORT=3478
TURN_TLS_PORT=5349
# Set to "true" once you've configured TLS certs on coturn.
TURN_TLS=false

# Comma-separated STUN URLs returned alongside TURN.
STUN_URLS=stun:stun.l.google.com:19302

# --- Auth (magic link) ---
# Long random secret used to sign JWTs. Generate with: openssl rand -hex 32
# If unset, the server warns and falls back to a per-process secret (every
# restart invalidates outstanding tokens).
AUTH_JWT_SECRET=
# Origin the magic-link URL embeds (frontend reads ?magic=<token> off it).
MAGIC_LINK_BASE=http://localhost:8080
# Set true to require a valid session JWT on every socket.io connect.
AUTH_REQUIRED=false

# --- SMTP (optional, for the magic-link email + /mail/send feature) ---
# Leave empty to use Ethereal test transport.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SFU ---
# Room size at which the server flips from mesh to SFU.
SFU_MESH_MAX=4

# --- Observability ---
METRICS_INTERVAL_MS=5000
