# Used by docker-compose.yml.
# Copy to .env and fill in values.

# --- TURN / coturn ---
# Long random secret shared between coturn and the signaling server.
# Generate with: openssl rand -hex 32
TURN_SECRET=replace-with-output-of-openssl-rand-hex-32

# Realm advertised by coturn. Any string; should match what the backend uses.
TURN_REALM=socket-webrtc.local

# IP coturn advertises in relay candidates.
#   - localhost only:  127.0.0.1
#   - LAN testing:     <your machine's LAN IP, e.g. 192.168.1.42>
#   - cloud deploy:    <VM's public IP>
EXTERNAL_IP=127.0.0.1

# Hostname the backend tells clients to reach coturn at. Usually the same
# as EXTERNAL_IP for local; a DNS name in production.
TURN_HOST=127.0.0.1
TURN_PORT=3478
TURN_TLS=false

# --- Auth (magic link) ---
# Long random secret used to sign session JWTs.
# Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Origin the magic-link URL points at. The frontend reads ?magic=<token>
# off the path and POSTs it to /auth/redeem. For docker compose this
# defaults to http://localhost:8080.
MAGIC_LINK_BASE=http://localhost:8080

# --- SMTP (optional) ---
# Leave SMTP_HOST empty to use the Ethereal test transport (preview URL
# is surfaced in the API response).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SFU ---
# Room size at which the server flips from mesh to SFU.
SFU_MESH_MAX=4

# --- Frontend build-time ---
# Backend URL the frontend talks to. Inlined into the bundle by vite.
VITE_SIGNAL_URL=http://localhost:3000

# --- Observability ---
METRICS_INTERVAL_MS=5000
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
