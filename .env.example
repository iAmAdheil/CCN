# Used by docker-compose.yml.
# Copy to .env and fill in values.

# Long random secret shared between coturn and the signaling server.
# Generate with: openssl rand -hex 32
TURN_SECRET=replace-with-output-of-openssl-rand-hex-32

# Realm advertised by coturn. Any string; should match what the backend uses.
TURN_REALM=socket-webrtc.local

# IP coturn advertises in relay candidates.
#   - localhost only:  127.0.0.1
#   - LAN testing:     <your machine's LAN IP, e.g. 192.168.1.42>
#   - cloud deploy:    <VM's public IP>
EXTERNAL_IP=127.0.0.1
